NODE_ENV=development
PORT=3000

# PostgreSQL (RLS-enforced app user)
DATABASE_URL=postgresql://observability_app:observability_password@localhost:5435/ai_observability?schema=public

# PostgreSQL (RLS-bypassed superuser for auth/workers)
SYSTEM_DATABASE_URL=postgresql://postgres:postgres@localhost:5435/ai_observability?schema=public

# Redis (docker service)
REDIS_HOST=localhost
REDIS_PORT=6379
